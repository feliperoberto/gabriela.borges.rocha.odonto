{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/assert-in-container.js",
    "dev": "next dev",
    "prebuild": "node scripts/assert-in-container.js",
    "build": "next build",
    "prestart": "node scripts/assert-in-container.js",
    "start": "next start",
    "prelint": "node scripts/assert-in-container.js",
    "lint": "eslint",
    "pretype-check": "node scripts/assert-in-container.js",
    "type-check": "tsc --noEmit",
    "pretest": "node scripts/assert-in-container.js",
    "test": "vitest run --project unit",
    "pretest-changed": "node scripts/assert-in-container.js",
    "test-changed": "( [ -d .git ] || [ -d ../.git ] ) && vitest run --project unit --changed || vitest run --project unit",
    "validate": "npm run lint && npm run type-check && npm run test-changed",
    "preplaywright": "node scripts/assert-in-container.js",
    "playwright": "playwright test",
    "prestorybook": "node scripts/assert-in-container.js",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "node scripts/assert-in-container.js",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/nextjs-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-storybook": "^10.5.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "storybook": "^10.5.0",
    "typescript": "^5",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
